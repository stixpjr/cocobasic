10 'BININFO 2023-01-07
20 INPUT "FILE";F$
30 OPEN"I",#1,F$,1
40 CLOSE#1
50 OPEN"D",#1,F$,1
60 FIELD #1,1 AS A$
70 PRINT "LEOF:",HEX$(LOF(1));" (";STR$(LOF(1));")"
80 P=1
90 O=P:GOSUB 220:F=V
100 O=P+1:GOSUB 270:L=V
110 O=P+3:GOSUB 270:E=V
120 IF F=255 THEN 180
130 PRINT "PREAMBLE:"
140 PRINT " LENGTH:",HEX$(L);" (";STR$(L);")"
150 PRINT " LOAD:",HEX$(E);" (";STR$(E);")"
160 P=P+L+5
170 GOTO 90
180 PRINT "POSTAMBLE:"
190 PRINT " EXEC:",HEX$(E);" (";STR$(E);")"
200 CLOSE #1
210 END
220 ' READ BYTE FROM OFFSET O,
230 ' RETURN IN V
240 GET #1,O
250 V=ASC(A$)
260 RETURN
270 ' READ WORD FROM OFFSET O,
280 ' RETURN IN V
290 GET #1,O
300 V=ASC(A$)
310 GET #1,O+1
320 V=V*256+ASC(A$)
330 RETURN
