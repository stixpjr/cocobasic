10 'HEXDUMP 2022-02-12
20 INPUT "FILE";F$
30 OPEN "D", #1, F$, 1
40 FIELD #1, 1 AS B$
50 E=LOF(1)
60 O=0
70 IF O<0 THEN O=0
80 GOSUB 170
90 D$=INKEY$
100 IF LEN(D$)=0 THEN GOTO 90
110 IF D$=" "OR ASC(D$)=10 OR ASC(D$)=13 THEN O=O+15:GOTO70
120 IF D$="-"OR D$="B"OR ASC(D$)=94 THEN O=O-15:GOTO70
130 IF D$="Q" THEN GOTO 150
140 GOTO90
150 CLOSE #1
160 END
170 FOR L=0 TO 14
180 IF (O+L)*8>E THEN RETURN
190 A$=""
200 FOR B=1 TO 8
210 IF (O+L)*8+B>E THEN 250
220 GET #1, (O+L)*8+B
230 A$=A$+B$
240 NEXT B
250 L$=HEX$((O+L)*8)+": "
260 L$=STRING$(6-LEN(L$),"0")+L$
270 FOR B=1 TO 8
280 IF LEN(A$)>=B THEN 310
290 C$="  "
300 GOTO 330
310 C$=HEX$(ASC(MID$(A$,B,1)))
320 C$=STRING$(2-LEN(C$),"0")+C$
330 L$=L$+C$
340 NEXT B
350 L$=L$+" "
360 FOR B=1 TO 8
370 IF LEN(A$)>=B THEN 400
380 C$=" "
390 GOTO 430
400 C$=MID$(A$,B,1)
410 C=ASC(C$)
420 IF C<32 THEN C$=" "
430 L$=L$+C$
440 NEXT B
450 PRINT L$
460 NEXT L
470 RETURN

