10 ' FSCK 2024-06-08
20 ' PAUL RIPKE STIX@STIX.ID.AU
30 CLEAR1024
40 INPUT"DRIVE";D$
50 D=VAL(D$):D$=""
60 'FAT ARRAY
70 DIM FAT(80)
80 'MARKED/USED ARRAY
90 'MAP FAT TO FILENUM
100 DIM M(80)
110 'FILENAME ARRAY
120 DIM FIN$(80)
130 'FILE COUNT
140 FC=1
150 'READ FAT
160 DSKI$ D,17,2,A$,B$
170 FOR I=0 TO 79:FAT(I)=ASC(MID$(A$,I+1,1)):M(I)=0:NEXT I
180 'READ DIRECTORY SECTORS
190 FOR I=3 TO 11
200 A$="":B$=""
210 DSKI$ D,17,I,A$,B$
220 FOR E=0 TO 3
230 'DIRENT MARKED FREE
240 'FIRST BYTE OF FILENAME
250 K=ASC(MID$(A$,1+E*32,1)):IF K=&HFF OR K=0 THEN 570
260 'FILE TYPE (ASCII/BINARY)
270 T=ASC(MID$(A$,1+E*32+12,1))
280 IF T=0 THEN T$="B" ELSE IF T=&HFF THEN T$="A" ELSE T$="?"
290 'SIZE: BYTES IN LAST SECTOR
300 S=ASC(MID$(A$,1+E*32+14,1))*256+ASC(MID$(A$,1+E*32+15,1))
310 'ERROR STRING
320 Z$=""
330 'FOLLOW FAT GRANULE CHAIN
340 G=ASC(MID$(A$,1+E*32+13,1))
350 '1ST GRANULE MARKED FREE
360 IF G=&HFF THEN Z$="*G 1ST MARKED FREE":GOTO510
370 'GRANULE OUT OF BOUNDS
380 IF G>67 THEN Z$="*G"+STR$(G)+" OOB":GOTO510
390 'GRANULE ALREADY USED
400 IF M(G)<>0 THEN Z$="*G"+STR$(G)+" XLINK '"+FIN$(M(G))+"'":GOTO510
410 'GRANULE MARKED FREE
420 IF FAT(G)=&HFF THEN Z$="*G"+STR$(1+G)+" MARKED FREE":GOTO510
430 'VALID GRANULE
440 M(G)=FC:G=FAT(G)
450 'SECTORS IN LAST GRANULE
460 IF G=&HC0 THEN 510
470 IF G>&HC0 AND G<=&HC9 THEN S=S+(G-&HC1)*256:GOTO510
480 'FULL GRANULE ALLOCATED
490 S=S+256*9:GOTO380
500 'FILENAME & EXTENSION
510 FIN$(FC)=MID$(A$,1+E*32,8)+"/"+MID$(A$,1+E*32+8,3)
520 PRINT USING "## ";FC;:PRINT FIN$(FC);STR$(ASC(MID$(A$,1+E*32+11,1)));" ";T$;:PRINT USING "#######";S
530 'PRINT ERROR
540 IF Z$<>""THEN PRINT Z$
550 FC=FC+1
560 'NEXT DIRENT
570 NEXT E
580 'NEXT DIRENT 128 BYTE BLOCK
590 IF B$<>"" THEN A$=B$:B$="":GOTO 220
600 'NEXT DIRENT SECTOR
610 NEXT I
620 'CHECK GRANULES
630 FOR I=0TO67
640 G=FAT(I)
650 'LINKED+FREE HANDLED ABOVE
660 IF G=&HFF AND M(I)<>0 THEN760
670 IF G=&HFF THEN760
680 'VALID GRANULE
690 IF M(I)<>0 AND (G<68 OR (G>=&HC0 AND G<=&HC9)) THEN760
700 'LINKED+INVALID
710 IF M(I)<>0 THEN PRINT "*G"+STR$(I)+" LINKED '"+FIN$(M(I))+"'+INVALID":GOTO 760
720 'FAT POINTS TO INVALID GRANULE
730 IF (G>67 AND NOT (G>=&HC0 AND G<=&HC9)) THEN PRINT "*G"+STR$(I)+" INVALID":GOTO 760
740 'MARKED ALLOCATED BUT NOT LINKED
750 PRINT "*G"+STR$(I)+" UNLINKED":GOTO 760
760 NEXT I
770 PRINT"PRESS ANY KEY FOR DISK MAP"
780 A$=INKEY$:IF A$=""THEN780
790 CLS
800 FOR I=0 TO 67 STEP 10
810 PRINT USING "##";I;
820 FOR J=0 TO 9
830 PRINT USING " ##";M(I+J);
840 NEXT J
850 NEXT I
