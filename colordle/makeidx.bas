10 ' MAKEIDX
20 ' 2022-03-19
30 OPEN"D",#1,"GUESSES/DAT",5
40 FIELD#1,5 AS W$
50 WC=LOF(1)
60 OPEN"O",#2,"GUESSES/IDX"
70 A$=" AAAA"
80 FOR I=65 TO 90
90 MID$(A$,1,1)=CHR$(I)
100 GOSUB 180
110 PRINT C,W$
120 WRITE#2,C,W$
130 NEXT I
140 WRITE#2,WC+1,""
150 CLOSE#1
160 CLOSE#2
170 END
180 A=0:B=WC
190 C=INT((A+B)/2)
200 GET#1,C
210 IF A=C THEN RETURN
220 IF W$<A$ THEN A=C ELSE B=C
230 IF B-A>1 THEN 190
240 IF W$>A$ THEN RETURN
250 C=C+1:GET#1,C:RETURN
