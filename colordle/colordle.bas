10 ' COLORDLE: WORDLE FOR COCO1/2/3
20 ' 2024-08-26
30 ' PAUL RIPKE STIX@STIX.ID.AU
40 POKE65495,0
50 CLS:DIM C(26),GI(27),LS(26)
60 CH=0 ' CHEAT FOR TESTING
70 GOSUB 1800 ' INIT GRAPHICS FONT
80 POKE65494,0
90 ' WORDS/DAT
100 OPEN"D",#1,"WORDS/DAT",5
110 FIELD#1,5 AS W$:WC=LOF(1)
120 PRINT"WORDLE WORDLIST:";WC;"WORDS"
130 ' GUESSES/IDX
140 OPEN"I",#2,"GUESSES/IDX"
150 FOR I=1TO27:INPUT#2,GI(I),A$:NEXT I
160 CLOSE#2
170 ' GUESSES/DAT
180 OPEN"D",#2,"GUESSES/DAT",5
190 FIELD#2,5 AS G$:GC=LOF(2)
200 POKE65495,0
210 PRINT"UNLIMITED WORDLIST:";GC;"WORDS"
220 PRINT"(COLLINS SCRABBLE LIST 2019)"
230 PRINT:INPUT"PLAY UNLIMITED (Y/(N))";A$
240 IF LEFT$(A$,1)="Y" THEN U=1 ELSE U=0
250 I=RND(-TIMER) ' SEED RANDOM
260 PMODE3,1:PCLS:SCREEN1,1
270 ' DRAW TITLE
280 DRAW"BM114,2S8C2":Z$="COLORDLE":GOSUB 1720
290 DRAW"BM114,14S8C0":Z$="WORDLE ON COCO":GOSUB 1720
300 DRAW"BM114,26S8C0":Z$="BY PAUL RIPKE":GOSUB 1720
310 ' DRAW HELP TEXT
320 COLOR 2,1
330 LINE(110,48)-(130,72),PSET,BF
340 DRAW"BM114,52S16C1":Z$="A":GOSUB 1720
350 COLOR 0,1
360 DRAW"BM134,50S8C0":Z$="RIGHT LETTER":GOSUB 1720
370 DRAW"BM134,62S8C0":Z$="RIGHT PLACE":GOSUB 1720
380 COLOR 0,1
390 LINE(110,72)-(130,96),PSET,BF
400 DRAW"BM114,76S16C1":Z$="B":GOSUB 1720
410 DRAW"BM134,74S8C0":Z$="RIGHT LETTER":GOSUB 1720
420 DRAW"BM134,86S8C0":Z$="WRONG PLACE":GOSUB 1720
430 LINE(110,96)-(130,120),PSET,B
440 DRAW"BM114,100S16C0":Z$="C":GOSUB 1720
450 DRAW"BM134,98S8C0":Z$="WRONG LETTER":GOSUB 1720
460 ' NEW WORD LOOP
470 POKE65494,0
480 IF U=1 THEN GET#2,RND(GC):W$=G$ ELSE GET#1,RND(WC)
490 POKE65495,0
500 FOR I=1TO26:LS(I)=0:NEXT I
510 ' DRAW EMPTY GRID
520 COLOR 0,1
530 LINE(0,0)-(5*20,6*24),PRESET,BF
540 FOR Y=0 TO 6:LINE(0,Y*24)-(5*20,Y*24),PSET:NEXT Y
550 FOR X=0 TO 5:LINE(X*20,0)-(X*20,6*24),PSET:NEXT X
560 LINE(110,124)-(236,160),PRESET,BF
570 LS=0:FOR A=1TO26:GOSUB 1520:NEXT A
580 ' DRAW CHEAT
590 IF CH=0 THEN 620
600 LINE(0,146)-(60,158),PRESET,BF
610 DRAW"BM0,146S8C0":Z$=W$:GOSUB 1720
620 POKE65494,0:SOUND225,1:POKE65495,0:GN=0:LC=0:UG$=STRING$(5,32)
630 ' START GAME LOOP
640 ' CHECK STRING STACK LEAK
650 ' IF (PEEK(11)*256+PEEK(12))<>&H1A9 THEN STOP
660 ' EMPTY ASSIGNMENT FIXES IT
670 A$="":A$=INKEY$:IF A$="" THEN 670
680 A=ASC(A$)
690 IF A=3 THEN END
700 IF A<>8 AND A<>12 THEN 740
710 IF LC=0 THEN 630
720 LC=LC-1
730 GOSUB 1440:GOTO 630
740 IF A<65 OR A>90 THEN POKE65494,0:SOUND10,1:POKE65495,0:GOTO 630
750 ' PLACE LETTER
760 DRAW"BM"+STR$(LC*20+4)+","+STR$(GN*24+4)+"S16C0"
770 Z$=A$:GOSUB 1720
780 MID$(UG$,LC+1,1)=LEFT$(A$,1)
790 LC=LC+1:IF LC<5 THEN 630
800 A$="":A$=INKEY$:IF A$="" THEN 800
810 A=ASC(A$)
820 IF A=13 THEN 860
830 IF A=8 OR A=12 THEN 720
840 POKE65494,0:SOUND 10,1:POKE65495,0
850 GOTO 800
860 ' BINARY SEARCH GUESS LIST
870 ' USING INDEX ON 1ST LETTER
880 POKE65494,0
890 C=ASC(LEFT$(UG$,1))-64
900 A=GI(C)-1
910 B=GI(C+1)
920 C=INT((A+B)/2)
930 IF A=C OR B=C THEN 980
940 GET#2,C
950 IF UG$=G$ THEN 1030
960 IF UG$<G$ THEN B=C:GOTO 920
970 A=C:GOTO 920
980 ' INVALID WORD
990 SOUND 10,1:POKE65495,0
1000 Z$=UG$+" IS NOT A WORD":GOSUB 1460
1010 FOR LC=0TO4:GOSUB 1440:NEXT LC
1020 LC=0:GOTO 630
1030 ' VALID WORD
1040 SOUND 225,1:POKE65495,0
1050 FOR I=1TO26:C(I)=0:NEXT I
1060 FOR I=1TO5
1070 W=ASC(MID$(W$,I,1))-64:C(W)=C(W)+1
1080 NEXT I
1090 FOR LC=0TO4
1100 Z$=MID$(UG$,LC+1,1):A=ASC(Z$)-64
1110 IF Z$<>MID$(W$,LC+1,1) THEN 1170
1120 ' CORRECT LETTER
1130 C(A)=C(A)-1:LS(A)=2:GOSUB 1520
1140 COLOR 2,1
1150 LINE(LC*20,GN*24)-(LC*20+20,GN*24+24),PSET,BF
1160 DRAW"BM"+STR$(LC*20+4)+","+STR$(GN*24+4)+"S16C1":GOSUB 1720
1170 NEXT LC
1180 FOR LC=0TO4
1190 Z$=MID$(UG$,LC+1,1):A=ASC(Z$)-64
1200 IF Z$=MID$(W$,LC+1,1) THEN 1300
1210 IF C(A)=0 THEN 1290
1220 ' RIGHT LETTER, WRONG PLACE
1230 C(A)=C(A)-1
1240 IF LS(A)<1 THEN LS(A)=1:GOSUB 1520
1250 COLOR 0,1
1260 LINE(LC*20,GN*24)-(LC*20+20,GN*24+24),PSET,BF
1270 DRAW"BM"+STR$(LC*20+4)+","+STR$(GN*24+4)+"S16C1":GOSUB 1720
1280 GOTO 1300
1290 IF LS(A)=0 THEN LS(A)=-1:GOSUB 1520
1300 NEXT LC
1310 IF UG$<>W$ THEN 1370
1320 POKE65494,0
1330 PLAY"T6L4O2GO3CEL4.GL8EL2G"
1340 POKE65495,0
1350 Z$="CONGRATULATIONS YOU GOT IT":GOSUB 1460
1360 GOTO 460
1370 LC=0:GN=GN+1
1380 IF GN<6 THEN 630
1390 POKE65494,0:SOUND10,10:POKE65495,0
1400 Z$="THE WORD WAS "+W$:GOSUB 1460
1410 GOTO 460
1420 ' SUBROUTINES
1430 ' CLEAR GRID BOX
1440 LINE(LC*20+2,GN*24+2)-(LC*20+19,GN*24+23),PRESET,BF:RETURN
1450 ' WRITE MSG IN Z$ & WAIT
1460 DRAW"BM0,168S8C0":GOSUB 1720
1470 DRAW"BM0,180S8C0"
1480 Z$="PRESS ANY KEY":GOSUB 1720
1490 A$="":A$=INKEY$:IF A$=""THEN 1490
1500 LINE(0,168)-(255,191),PRESET,BF
1510 RETURN
1520 ' DRAW LETTER STATUS
1530 Y=0:X=A
1540 IF X>9 THEN Y=Y+1:X=X-9:GOTO 1540
1550 X=(X-1)*14+110:Y=Y*12+124
1560 IF LS(A)=2 THEN 1640
1570 IF LS(A)=1 THEN 1660
1580 IF LS(A)=0 THEN 1610
1590 LINE(X+2,Y+2)-(X+12,Y+10),PRESET,BF
1600 RETURN
1610 COLOR 0,1
1620 LINE(X,Y)-(X+14,Y+12),PSET,B
1630 DRAW"BM"+STR$(X+2)+","+STR$(Y+2)+"S8C0":GOTO 1690
1640 COLOR 2,1
1650 GOTO 1670
1660 COLOR 0,1
1670 LINE(X,Y)-(X+14,Y+12),PSET,BF
1680 DRAW"BM"+STR$(X+2)+","+STR$(Y+2)+"S8C1"
1690 Z$=CHR$(A+64):GOSUB 1720
1700 RETURN
1710 ' DRAW STRING IN Z$
1720 FOR I=1TOLEN(Z$)
1730 C=ASC(MID$(Z$,I,1))
1740 IF C=32 THEN DRAW AZ$(0):GOTO 1780
1750 IF C>=65 AND C<=90 THEN DRAW AZ$(C-64):GOTO 1780
1760 IF C>=48 AND C<=57 THEN DRAW NZ$(C-48):GOTO 1780
1770 DRAW AZ$(0)
1780 NEXT I
1790 RETURN
1800 ' SET UP GRAPHICS FONT
1810 DIM AZ$(26),NZ$(9)
1820 FOR I=0TO26:READ AZ$(I):NEXT I
1830 FOR I=0TO9:READ NZ$(I):NEXT I
1840 ' ALPHAS
1850 DATA BR4,ND4R3D2NL3D2BU4BR2,D4R2E1H1NL2E1H1L2BR5,D4R3BU4L3BR5,D4R2E1U2H1L2BR5,D2NR2D2R3BU4L3BR5,NR3D2NR2D2BE4BR1,NR3D4R3U2L1BE2BR1,D2ND2R3D2U4BR2,R2L1D4L1R2BR2BU4,BD3D1R3U4BR2,D4U2RNF2E2BR2
1860 DATA D4R3BU4BR2,ND4F2E2ND4BR2,ND4F3D1U4BR2,D4R3U4L3BR5,ND4R3D2L3BR5BU2,D4R1E1NF1E1U2L3BR5,ND4R3D2L3R1F2BR2BU4,NR3D2R3D2L3BR5BU4,R2L1D4BR3BU4,D4R3U4BR2,D2F2E2U2BR2,D4E2F2U4BR2,F4BL4E4BR2
1870 DATA F2ND2E2BR2,R4G4R4BU4BR2
1880 ' DIGITS
1890 DATA D4R3U4L3BR5,BRND4BR3,R3D2L3D2R3BU4BR2,R3D2NL3D2L3BU4BR5,D2R2NU2ND2RBU2BR2,NR3D2R3D2L3BU4BR5,NR3D4R3U2L3BU2BR5,R3DG3BE4BR1,D4R3U2NL3U2L3BR5,D2BD2R3U2NL3U2L3BR5
1900 RETURN
